// Schema Prisma para MongoDB — catálogo da loja (produtos + categorias + hero).
// Após alterar: `npx prisma db push --schema=./prisma/schema-mongodb.prisma` e `npm run prisma:generate`.
// Output em node_modules (não `.prisma/` na raiz) para evitar EPERM no Windows ao substituir query_engine com o IDE aberto.
generator client {
  provider      = "prisma-client-js"
  output        = "../node_modules/.prisma-mongodb"
  // native = dev local; rhel-openssl-3.0.x = Vercel/serverless Linux x64; musl-arm64 = Render ARM Alpine (catalog-agent)
  binaryTargets = ["native", "rhel-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

model Category {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String    @unique
  slug        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@map("categories")
}

// Documento na coleção `products`. Campos novos alinham ao relatório LW (Excel/PDF).
// `slug` continua a ser o identificador de URL; `codigo` é o código comercial (único quando existe).
model Product {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  /// Código do fornecedor / relatório LW (ex.: 16503). Único quando preenchido; importações fazem match aqui se o slug mudar.
  codigo       String?  @unique
  name         String
  /// Slug URL-friendly; derivado de código+nome nas importações (ver importRowSlug).
  slug         String   @unique
  description  String
  /// Custo (interno). No Excel calcula-se como Vl.Est.Custo / estoque quando faz sentido.
  cost         Float?
  /// Preço unitário à vista — é o que o catálogo usa como `price`.
  price        Float
  /// Preço a prazo (coluna do PDF LW); opcional no Excel de estoque.
  pricePrazo   Float?
  stock        Int      @default(0)
  minStock     Int      @default(0)
  /// Unidade de venda (ex.: UN, KG) quando vem no PDF.
  unidade      String?
  /// Peso em kg; no PDF o campo “peso” grava aqui (mantém o nome `weight` no Prisma por compatibilidade com o código antigo).
  weight       Float?
  /// EAN / código de barras numérico (apenas dígitos no import).
  codBarra     String?
  /// Marca do relatório LW (coluna «Marca» no Excel). PDF não traz marca → fica null.
  marca        String?
  /// Subcategoria (ex.: coluna «Grupo» do relatório). Usado para filtros no catálogo, sem criar Categories novas.
  subcategoria String?
  /// Origem (controlo interno): "import" ou "manual".
  origin       String?  @default("manual")
  /// true = ATIVO, false = INATIVO. O catálogo público filtra `status !== false`.
  status       Boolean  @default(true)
  featured     Boolean  @default(false)
  /// Se false, o produto não entra nas listagens da página inicial (continua no catálogo / URL).
  showOnHome   Boolean  @default(true)
  imageUrl     String?
  imageUrls    String[] @default([])
  /// Obrigatório: todo produto pertence a uma Category (relação em cascade).
  categoryId   String   @db.ObjectId
  /// Texto livre (ex.: dimensões para envio); enriquecimento ML/Gemini pode preencher.
  dimensionsCm String?
  /// NCM (8 dígitos) para fiscal/nota. Pode ser preenchido por enriquecimento via EAN.
  ncm         String?
  /// Última pré-visualização do enriquecimento por EAN (Master); evita repetir o lote até pedires «incluir já consultados».
  eanEnrichmentCheckedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("products")
  @@index([categoryId])
  @@index([featured])
  @@index([showOnHome])
  @@index([marca])
  @@index([subcategoria])
  @@index([origin])
  @@index([eanEnrichmentCheckedAt])
  @@index([ncm])
}

model HeroImage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  imageUrl  String
  alt       String   @default("Imagem do Hero")
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hero_images")
  @@index([order])
  @@index([active])
}



