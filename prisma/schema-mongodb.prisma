// Schema Prisma para MongoDB - Produtos e Categorias
generator client {
  provider = "prisma-client-js"
  output   = "../.prisma/mongodb-client"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URI")
}

model Category {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String    @unique
  slug        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@map("categories")
}

model Product {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String   @unique
  description String
  price       Float
  stock       Int      @default(0)
  weight      Float?   // Peso em kg
  imageUrl    String?
  categoryId  String   @db.ObjectId
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("products")
  @@index([categoryId])
  @@index([featured])
}

model HeroImage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  imageUrl  String
  alt       String   @default("Imagem do Hero")
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hero_images")
  @@index([order])
  @@index([active])
}
