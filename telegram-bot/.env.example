# Token do @BotFather
TELEGRAM_BOT_TOKEN=

# Mesma chave configurada no servidor Next (TELEGRAM_INTEGRATION_KEY)
TELEGRAM_INTEGRATION_KEY=

# URL pública do site (sem barra no fim), ex.: https://www.exemplo.com ou http://localhost:3000
MACOFEL_BASE_URL=https://www.macofelparapua.com

# Render Web Service define PORT automaticamente — não precisa no .env local.
# Para o plano grátis não adormecer, use um ping externo (ex. UptimeRobot) a GET https://<serviço>.onrender.com/
