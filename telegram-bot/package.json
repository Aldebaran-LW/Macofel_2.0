{
  "name": "macofel-telegram-bot",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npm exec --yes --package=esbuild@0.25.5 -- esbuild src/index.ts --bundle --platform=node --packages=external --format=esm --outfile=dist/index.js",
    "typecheck": "npm exec --yes --package=typescript@5.2.2 -- tsc --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "dotenv": "16.5.0",
    "grammy": "1.35.1"
  },
  "devDependencies": {
    "@types/node": "^20.6.2",
    "tsx": "4.20.3",
    "typescript": "^5.2.2"
  }
}
