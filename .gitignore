# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/telegram-bot/node_modules/

# bot TypeScript build
/telegram-bot/dist/
# venv Python acidental em lib/ (não versionar)
lib/site-packages/
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# vercel
.vercel
!.vercel/project.json

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma
.prisma/

# dotenv environment variable files
.env
.env.*
!.env.example
!telegram-bot/.env.example
# Environment files
*.env
*.env.*
!PDV.env.example

# Backups locais do catálogo MongoDB (não commitar)
/temp/

# Instalador PDV (binários grandes — copiar para public/downloads no deploy)
/public/downloads/*.exe
/public/downloads/*.msi

# Emergent
.emergent/

# Git config (local configuration)
.gitconfig

# Binários / cache de Python copiados por engano para scripts/ (não versionar)
/scripts/**/*.exe
/scripts/__pycache__/

# Resíduos de instalação Python na raiz (ex. man pages de pacotes)
/share/
