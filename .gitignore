# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/telegram-bot/node_modules/

# bot TypeScript build
/telegram-bot/dist/
# venv Python acidental em lib/ (não versionar)
lib/site-packages/
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# vercel
.vercel
!.vercel/project.json

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma
.prisma/

# dotenv environment variable files
.env
.env.*
!.env.example
!telegram-bot/.env.example
# Environment files
*.env
*.env.*
!PDV.env.example

# Exportações de enriquecimento (dados do catálogo — não commitar)
/exports/*
!/exports/README.md

# Backups locais do catálogo MongoDB (não commitar)
/temp/
/mongo-backup-swap-*/
/mongo-backup-manual/

# Instalador PDV (binários grandes — copiar para public/downloads no deploy)
/public/downloads/*.exe
/public/downloads/*.msi

# Emergent
.emergent/

# Git config (local configuration)
.gitconfig

# Binários / cache de Python copiados por engano para scripts/ (não versionar)
/scripts/**/*.exe
/scripts/__pycache__/

# Resíduos de instalação Python na raiz (ex. man pages de pacotes)
/share/

# Pipeline de enriquecimento Macofel (local — saídas e credenciais Abacus)
/Macofel_Enriquecimento/.env
/Macofel_Enriquecimento/**/.abacus.donotdelete
/Macofel_Enriquecimento/macofel_enriched_products*.json
/Macofel_Enriquecimento/macofel_enrichment_report*.html
/Macofel_Enriquecimento/buscas_arquivadas/
/Macofel_Enriquecimento/Uploads/enrichment-input.catalog.json
/Macofel_Enriquecimento/Uploads/enrichment-ai-knowledge-draft.json
/Macofel_Enriquecimento/Uploads/test-secondary-ai-draft.json
/Macofel_Enriquecimento/Uploads/test-secondary-ai-draft.html
/Macofel_Enriquecimento/Uploads/enrichment-from-draft-report.json
/Macofel_Enriquecimento/blocked_fetch_domains.json
/Macofel_Enriquecimento/Lib/
/Macofel_Enriquecimento/Scripts/
